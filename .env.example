# Copy this file to .env and fill in your values

# Your bot's token from https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# Right-click the #wordle channel → Copy Channel ID (enable Developer Mode first)
WORDLE_CHANNEL_ID=123456789012345678

# Right-click your leaderboard channel → Copy Channel ID
LEADERBOARD_CHANNEL_ID=123456789012345678

# The display name of the Wordle Discord app in your server (partial match, case-insensitive)
WORDLE_BOT_NAME=Wordle

# The role name that can use the /leaderboard slash command
MOD_ROLE=Program Staff

# Minimum games played to appear on the leaderboard
MIN_GAMES=5

# Maximum players shown on the leaderboard
TOP_N=7

# Hour (UTC) on the 1st of each month to post the leaderboard (0-23)
POST_HOUR_UTC=9
